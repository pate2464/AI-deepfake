# AI Fraud Detector — Environment Variables
# Copy this file to .env and fill in your keys

# ── App ──────────────────────────────────────────────────
DEBUG=true
# API_PREFIX=/api/v1

# ── Database ─────────────────────────────────────────────
# Local (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./fraud_detector.db
# Production (Vultr Managed PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://user:password@host:port/dbname

# ── Gemini ───────────────────────────────────────────────
# Primary semantic VLM. If unavailable, the backend falls back to local Moondream2.
GEMINI_API_KEY=
GEMINI_MODEL=models/gemini-3.1-pro-preview

# ── Model prefetch (optional) ────────────────────────────
# Used by backend/download_models.py to prefetch optional probe/weights files into backend/models/.
# If unset, the backend still runs but may fall back to heuristics for some layers.
# CLIP_PROBE_URL=
# CLIP_PROBE_SHA256=
# CNNDETECTION_WEIGHTS_URL=
# CNNDETECTION_WEIGHTS_SHA256=

# ── Object Storage (S3-compatible, e.g. Vultr) ──────────
OBJECT_STORAGE_ENABLED=false
OBJECT_STORAGE_ENDPOINT_URL=https://ewr1.vultrobjects.com
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_PREFIX=uploads

# ── ML Models ────────────────────────────────────────────
# MODEL_CACHE_DIR=./models
# ENABLE_DIRE=true

# ── Upload ───────────────────────────────────────────────
# UPLOAD_DIR=./uploads
# MAX_FILE_SIZE_MB=20
